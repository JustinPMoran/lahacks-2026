# Copy to .env and fill in real values. .env is gitignored.

# MongoDB Atlas connection URI. Get from cloud.mongodb.com -> "Connect" -> "Drivers"
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=csi_demo
MONGODB_COLLECTION=motion_log
MONGODB_RAW_COLLECTION=csi_raw
MONGODB_DEVICES_COLLECTION=devices
MONGODB_SESSIONS_COLLECTION=capture_sessions
MONGODB_SAMPLES_COLLECTION=sensor_samples

# Optional Google Gemini enrichment for sensor_samples.
GOOGLE_API_KEY=
GEMINI_MODEL=gemma-4-26b-a4b-it
DISABLE_GEMINI=false

# Serial reader and legacy receiver metadata.
CSI_SERIAL_PORT=/dev/cu.usbserial-130
CSI_SERIAL_BAUD=921600
CSI_NODE_ID=rx-01
LOG_RAW_CSI=false
FLUSH_SECONDS=1.0

# Device registry metadata.
DEVICE_ID=esp32s3_001
DEVICE_TYPE=esp32-s3
FIRMWARE_NAME=wifi-sensing-fw
FIRMWARE_VERSION=0.1.0
ESP_IDF_VERSION=v5.2.1
HARDWARE_CHIP=ESP32-S3
BOARD_MODEL=custom
MAC_ADDR_WIFI_STA=AA:BB:CC:DD:EE:FF
MAC_ADDR_WIFI_AP=AA:BB:CC:DD:EE:00

# Capture session metadata.
SUBJECT_ID=participant_01
ACTIVITY_NAME=walking
ACTIVITY_LABEL_ID=0
ANNOTATION_SOURCE=manual
ENV_SITE=lab_a
ENV_ROOM=conference_room
ENV_NOTES=single person, door closed
SESSION_TAGS=train,baseline

# WiFi CSI capture config.
WIFI_MODE=station
WIFI_CHANNEL=6
WIFI_BANDWIDTH=HT20
ROUTER_BSSID=11:22:33:44:55:66
SAMPLE_RATE_HZ=100
SAMPLE_WINDOW_MS=5000
